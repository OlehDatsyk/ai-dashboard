# =========================================================
# AI Dashboard - Environment Variables
# Copy this file to ".env" and fill in the values below.
#   cp .env.example .env
# =========================================================

# --- OpenAI ---------------------------------------------------------------
# Your OpenAI API key. Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Default model used by the AI Chat / Prompt Playground.
# Any model that supports the Responses API can be used.
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# Default sampling temperature (0.0 - 2.0)
OPENAI_DEFAULT_TEMPERATURE=0.7

# Default system prompt shown in the Prompt Playground / Chat widget
OPENAI_SYSTEM_PROMPT="You are a helpful, concise AI assistant embedded inside an analytics dashboard."

# --- Flask -----------------------------------------------------------------
FLASK_APP=app.py
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=change-this-to-a-random-secret-value

# Host / port the dev server binds to
HOST=127.0.0.1
PORT=5000

# --- Application -------------------------------------------------------------
# Where analytics/usage data is persisted (JSON file storage)
DATA_DIR=data

# Application display name, shown in the dashboard UI
APP_NAME=AI Dashboard

# Currency used for cost estimation display purposes
CURRENCY_SYMBOL=$
